<?xml version="1.0" encoding="UTF-8"?>
<ruleset xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" comparisonMethod="maven" xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0 http://mojo.codehaus.org/versions-maven-plugin/xsd/rule-2.0.0.xsd">
    <ignoreVersions>
        <!-- Ignore Alpha's, Beta's, release candidates and milestones -->
        <ignoreVersion type="regex">(?i).*Alpha(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*a(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*Beta(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*jdk5(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*-B(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*RC(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*CR(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*M(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*Dev(?:[-\.]?\d+)?</ignoreVersion>
        <ignoreVersion type="regex">(?i).*ea(?:[+-\.]?\d+)?</ignoreVersion>
    </ignoreVersions>
    <rules>
        <rule groupId="org.springframework.ai">
            <ignoreVersions>
                <ignoreVersion type="regex">(?i).*Alpha(?:[-\.]?\d+)?</ignoreVersion>
                <ignoreVersion type="regex">(?i).*a(?:[-\.]?\d+)?</ignoreVersion>
                <ignoreVersion type="regex">(?i).*Beta(?:[-\.]?\d+)?</ignoreVersion>
                <ignoreVersion type="regex">(?i).*RC(?:[-\.]?\d+)?</ignoreVersion>
                <ignoreVersion type="regex">(?i).*CR(?:[-\.]?\d+)?</ignoreVersion>
                <ignoreVersion type="regex">(?i).*Dev(?:[-\.]?\d+)?</ignoreVersion>
                <ignoreVersion type="regex">(?i).*ea(?:[+-\.]?\d+)?</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.jetbrains.kotlinx">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.seleniumhq.selenium">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.springframework.ldap">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.thymeleaf">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.thymeleaf.extras">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.xmlunit">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.jooq">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.mongodb">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.mongodb.scala">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
        <rule groupId="org.springframework.amqp">
            <ignoreVersions>
                <ignoreVersion type="regex">.*</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>
</ruleset>
